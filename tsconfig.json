{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "plugins": [{ "name": "@effect/language-service" }],
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "confect/**/*.ts",
    "convex/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "tools/**/*.ts"
  ]
}
