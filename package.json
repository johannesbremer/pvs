{
  "name": "pvs",
  "version": "0.1.0",
  "private": true,
  "description": "KBV-aligned PVS prototype built on Confect and Convex",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "codegen": "confect codegen",
    "effect:patch": "effect-language-service patch",
    "format": "prettier --write .",
    "format:list": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "oracle:coverage-inventory": "node tools/oracles/print-coverage-inventory.mjs",
    "oracle:official-corpus-inventory": "node tools/oracles/print-official-corpus-inventory.mjs",
    "oracle:prefetch": "node --experimental-strip-types tools/oracles/prefetch.mjs",
    "test": "vitest run --exclude 'test/overnight/**/*.test.ts'",
    "test:fhir:fixtures": "vitest run test/executable-fhir-oracle.test.ts test/official-kbv-fixtures.test.ts test/official-evdga-fixtures.test.ts --reporter=verbose",
    "test:property": "node tools/oracles/reset-overnight-dashboard.mjs && PVS_PROPERTY_RUNS=${PVS_PROPERTY_RUNS:-1000000} PVS_ORACLE_TEST_TIMEOUT_MS=${PVS_ORACLE_TEST_TIMEOUT_MS:-86400000} vitest --config vitest.overnight.config.ts test/overnight/erezept-emitter-oracle.test.ts test/overnight/erezept-differential-oracle.test.ts --ui",
    "tsc": "pnpm effect:patch && tsc --noEmit",
    "typecheck": "pnpm effect:patch && tsc --noEmit"
  },
  "dependencies": {
    "@confect/cli": "^2.0.0",
    "@confect/core": "latest",
    "@confect/server": "latest",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "convex": "^1.32.0",
    "effect": "latest"
  },
  "devDependencies": {
    "@confect/test": "latest",
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@effect/language-service": "^0.80.0",
    "@effect/vitest": "^0.27.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@eslint/markdown": "^7.5.1",
    "@types/node": "latest",
    "@vitest/eslint-plugin": "^1.6.10",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-jsonc": "^3.1.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-package-json": "^0.90.1",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-yml": "^3.3.1",
    "fast-check": "latest",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "latest",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.18.1"
}
